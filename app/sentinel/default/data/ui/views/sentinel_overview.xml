  <!-- ===================================================================
       ROW 2 — Quick stats
       =================================================================== -->
  <row>
    <panel>
      <title>TOTAL CASES (24H)</title>
      <single>
        <search>
          <query>
            index=sentinel_cases earliest=-24h latest=now
            | stats count as total_cases
          </query>
          <earliest>-24h</earliest>
          <latest>now</latest>
          <refresh>60s</refresh>
          <refreshType>delay</refreshType>
        </search>
        <option name="drilldown">none</option>
        <option name="refresh.display">progressbar</option>
        <option name="numberPrecision">0</option>
      </single>
    </panel>

    <panel>
      <title>AVG MTTR (24H)</title>
      <single>
        <search>
          <query>
            index=sentinel_cases status=CLOSED earliest=-24h latest=now
            | eval response_minutes=round((updated_time-created_time)/60,1)
            | stats avg(response_minutes) as mttr
            | eval mttr=round(mttr,1)
          </query>
          <earliest>-24h</earliest>
          <latest>now</latest>
          <refresh>60s</refresh>
          <refreshType>delay</refreshType>
        </search>
        <option name="drilldown">none</option>
        <option name="refresh.display">progressbar</option>
        <option name="unit">min</option>
        <option name="unitPosition">after</option>
        <option name="numberPrecision">0.0</option>
        <option name="useColors">true</option>
        <option name="colorMode">block</option>
        <option name="rangeValues">[10]</option>
        <option name="colorBy">value</option>
      </single>
    </panel>

    <panel>
      <title>THREATS NEUTRALIZED (7D)</title>
      <single>
        <search>
          <query>
            index=sentinel_cases status=CLOSED resolution!=FALSE_POSITIVE earliest=-7d latest=now
            | stats count as neutralized
          </query>
          <earliest>-7d</earliest>
          <latest>now</latest>
          <refresh>60s</refresh>
          <refreshType>delay</refreshType>
        </search>
        <option name="drilldown">none</option>
        <option name="refresh.display">progressbar</option>
        <option name="numberPrecision">0</option>
        <option name="useColors">true</option>
        <option name="colorMode">block</option>
        <option name="rangeValues">[1]</option>
        <option name="colorBy">value</option>
        <option name="charting.fieldColors">{"neutralized":#2ED573}</option>
      </single>
    </panel>

    <panel>
      <title>FALSE POSITIVE RATE (7D)</title>
      <single>
        <search>
          <query>
            index=sentinel_cases earliest=-7d latest=now
            | stats count as total, sum(eval(resolution="FALSE_POSITIVE")) as fp
            | eval fp_rate=if(total>0, round((fp/total)*100,1), 0)
            | fields fp_rate
          </query>
          <earliest>-7d</earliest>
          <latest>now</latest>
          <refresh>60s</refresh>
          <refreshType>delay</refreshType>
        </search>
        <option name="drilldown">none</option>
        <option name="refresh.display">progressbar</option>
        <option name="unit">%</option>
        <option name="unitPosition">after</option>
        <option name="numberPrecision">0.0</option>
        <option name="useColors">true</option>
        <option name="colorMode">block</option>
        <option name="rangeValues">[10,30]</option>
        <option name="colorBy">value</option>
      </single>
    </panel>
  </row>

